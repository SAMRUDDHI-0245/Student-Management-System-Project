<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="AddStudentController"
           stylesheets="@style.css">

    <VBox alignment="CENTER">

        <!-- TOP BAR : BACK BUTTON + TITLE -->
        <HBox spacing="10" alignment="CENTER_LEFT" prefWidth="500">
            <Button text="⬅ Back" onAction="#goBack"/>
            <Label text="➕ Add Student"
                styleClass="header"
                prefWidth="440"/>
        </HBox>


        <!-- WHITE CARD FORM -->
        <VBox styleClass="card" spacing="15" alignment="CENTER" prefWidth="500">

            <GridPane hgap="15" vgap="15">

            <Label text="Roll Number:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="rollField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

            <Label text="Name:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <Label text="Age:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <TextField fx:id="ageField" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

            <Label text="Course:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <TextField fx:id="courseField" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

            <!-- 5 NEW SUBJECT FIELDS -->
            <Label text="English:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
            <TextField fx:id="englishField" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

            <Label text="Hindi:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
            <TextField fx:id="hindiField" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

            <Label text="Mathematics:" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
            <TextField fx:id="mathField" GridPane.columnIndex="1" GridPane.rowIndex="6"/>

            <Label text="Science:" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
            <TextField fx:id="scienceField" GridPane.columnIndex="1" GridPane.rowIndex="7"/>

            <Label text="SST:" GridPane.columnIndex="0" GridPane.rowIndex="8"/>
            <TextField fx:id="sstField" GridPane.columnIndex="1" GridPane.rowIndex="8"/>

            </GridPane>


            <Button text="➕ Add Student" onAction="#addStudent" />
            <Button text="📄 View Students" onAction="#openTable" />

        </VBox>
    </VBox>
</StackPane>
